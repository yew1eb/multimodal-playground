# Gravitino 连接配置
GRAVITINO_ENDPOINT=http://localhost:8090
GRAVITINO_METALAKE=metalake_demo
GRAVITINO_CATALOG=demo_fileset_catalog
GRAVITINO_SCHEMA=demo
GRAVITINO_USERNAME=admin
GRAVITINO_AUTH_TYPE=simple

# Fileset 名称（本地 fileset 示例使用）
INPUT_FILESET=input
OUTPUT_FILESET=output

# S3/MinIO 连接配置（S3 示例使用）
# 这些值与 gravitino-playground/docker-compose.yaml 中 MinIO 的默认值保持一致。
# 注意：从宿主机访问时使用 http://localhost:9000；Docker 内部访问时使用 http://minio:9000。
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET=gravitino-bucket
S3_PATH_STYLE_ACCESS=true

# S3 -backed fileset catalog/schema/fileset 名称
# gravitino-playground 启动后已经默认创建了 catalog_s3，位置为 s3a://gravitino-bucket/fileset/
S3_CATALOG=catalog_s3
S3_SCHEMA=demo_s3
S3_INPUT_FILESET=input_s3
S3_OUTPUT_FILESET=output_s3
